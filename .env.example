# Vigil environment. Copy to .env and fill in.
#
# DEV: unset vars fall back to local defaults — the demo runs with ZERO secrets.
# PROD (VIGIL_ENV=production): the vars marked [prod-required] must be set or the
# service refuses to boot (fail closed). Secrets are injected at runtime and must
# never be committed (.env is gitignored; .dockerignore excludes it from images).

# ── Mode ───────────────────────────────────────────────────────────────────
VIGIL_ENV=development           # development | production. Selects fail-closed
                                # behavior; overrides NODE_ENV if both are set.
LOG_LEVEL=                      # pino level (debug|info|warn|error). Default:
                                # debug in dev, info in prod.

# ── Service URLs ───────────────────────────────────────────────────────────
NEXT_PUBLIC_AGENT_URL=http://localhost:4000   # BUILD-TIME. Browser → agent SSE.
PAYMENTS_URL=http://localhost:4100            # agent → mock prod
GATE_URL=http://localhost:4200                # agent + payments → gate   [prod-required]
WORKER_URL=http://localhost:4400              # agent → Akash worker      [prod-required for agent]
POMERIUM_URL=http://localhost:4300            # agent → destructive routes via proxy [prod-required for agent]

# ── Service-to-service auth (HMAC) — [prod-required] ───────────────────────
# Generate: openssl rand -hex 24   (>=16 chars each)
VIGIL_INTERNAL_SECRET=          # shared by gate/payments/worker/agent (signs +
                                # verifies every internal call). [prod-required]
WORKER_ATTEST_SECRET=           # gate + worker ONLY (NOT the agent) — the worker
                                # signs sandbox attestations, the gate verifies
                                # them, so the agent cannot forge sandbox proof.
                                # [prod-required]

# ── Grant store — [prod-required for the gate] ─────────────────────────────
REDIS_URL=                      # e.g. redis://redis:6379. Shared, atomic,
                                # single-use grants across replicas. Unset in dev
                                # ⇒ in-memory store. [prod-required]

# ── Zero.xyz log-parse capability ──────────────────────────────────────────
ZERO_MODE=fallback              # "live" once a funded Zero credential exists
ZERO_API_KEY=                   # from the Zero booth (docs/zero-receipts.md)
ZERO_API_URL=                   # only if the booth gives an HTTP gateway
ZERO_CAPABILITY=                # capability id from `zero search`
# Advanced Zero overrides (sensible defaults in integrations/zero-live.ts):
# ZERO_BIN=zero  ZERO_URL=...  ZERO_FIELDS=...  ZERO_MAX_PAY=0.10

# ── OpenAI hypothesis step (optional) ──────────────────────────────────────
# ROTATE any key that was ever shared in chat; never commit a live key.
OPENAI_API_KEY=                 # optional one-sentence root-cause hypothesis
OPENAI_MODEL=gpt-4o-mini        # override the hypothesis model if desired

# ── Observability (optional) ───────────────────────────────────────────────
SENTRY_DSN=                     # enable Sentry error reporting (needs @sentry/node)
OTEL_EXPORTER_OTLP_ENDPOINT=    # enable OpenTelemetry tracing (needs @opentelemetry/*)
MAX_SSE_CLIENTS=50              # cap concurrent SSE subscribers on the agent
